# Copy this file to .env.local and fill in your own values.
# Both URLs come from the Neon Console:
#   - VITE_NEON_AUTH_URL      → Auth ▸ Configuration ▸ "Auth URL"
#   - VITE_NEON_DATA_API_URL  → Data API ▸ "API URL"

VITE_NEON_AUTH_URL=https://YOUR-PROJECT.neonauth.REGION.aws.neon.tech/neondb/auth
VITE_NEON_DATA_API_URL=https://YOUR-PROJECT.apirest.REGION.aws.neon.tech/neondb/rest/v1
